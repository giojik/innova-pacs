events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;
    sendfile        on;
    keepalive_timeout  65;

    # 1. Cloudflare Real IP
    set_real_ip_from 103.21.244.0/22; 
    set_real_ip_from 103.22.200.0/22; 
    set_real_ip_from 103.31.4.0/22;
    set_real_ip_from 104.16.0.0/13; 
    set_real_ip_from 108.162.192.0/18; 
    set_real_ip_from 131.0.72.0/22;
    set_real_ip_from 141.101.64.0/18; 
    set_real_ip_from 162.158.0.0/15; 
    set_real_ip_from 172.64.0.0/13;
    set_real_ip_from 173.245.48.0/20; 
    set_real_ip_from 188.114.96.0/20; 
    set_real_ip_from 190.93.240.0/20;
    set_real_ip_from 197.234.240.0/22; 
    set_real_ip_from 198.41.128.0/17;
    real_ip_header CF-Connecting-IP;

    # 2. ქვეყნების ბლოკირება
    map $http_cf_ipcountry $allowed_country {
        default no;
        "" yes; 
        GE yes; 
        DE yes; 
        FR yes; 
        NL yes;
        AT yes;
    }
    # ეს კოდი დაამატეთ 'server' ბლოკის გარეთ, 'http' ბლოკში
    map $cookie_doctor_token $doctor_auth_header {
        default "";
        "~.+"   "Bearer $cookie_doctor_token";
    }

    # ლოგიკა: რომელი კონფიგურაცია მივცეთ (თუ ექიმი შესულია, მივცეთ საჯარო კონფიგი)
    map "$cookie_patient_auth$cookie_doctor_token" $ohif_config {
        ""        "/etc/nginx/scripts/app-config.js";        # არცერთი ტოკენი არაა -> ლოგინი
        default   "/etc/nginx/scripts/app-config-public.js"; # რომელიმე ტოკენი არის -> საჯარო
    }
    
    server {
        listen 80;
        server_name ris.innovamedical.ge;
        return 301 https://$host$request_uri;
    }

    server {
        listen 443 ssl;
        server_name ris.innovamedical.ge;

        include /etc/nginx/conf.d/ae_title.conf;

        location = /favicon.ico {
            alias /etc/nginx/static/favicon.ico;
            allow all; # ნება დართე ყველას
            access_log off;
            log_not_found off;
        }

        if ($allowed_country = no) { return 403; }

        ssl_certificate /etc/nginx/certs/live/ris.innovamedical.ge/fullchain.pem;
        ssl_certificate_key /etc/nginx/certs/live/ris.innovamedical.ge/privkey.pem;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # --- OHIF კონფიგურაციის მიწოდება (გასწორებული) ---
        location = /app-config.js {
            default_type application/javascript;
            alias $ohif_config;
            
            # აქ ვიყენებთ დროებით ტექსტს, რომელსაც სერვერი ჩაანაცვლებს
            sub_filter 'AE_TITLE_PLACEHOLDER' '${AE_TITLE}';
            sub_filter_once off;
            
            add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0";
            expires off;
            proxy_no_cache 1;
        }

        # 1. მთავარი გვერდი - თუ ვინმე მხოლოდ ris.innovamedical.ge-ს აკრიფავს, 
        # ის მაშინვე გადამისამართდეს ჩვენს ახალ, სწრაფ Login გვერდზე.
        location = / {
            return 301 https://$host/login;
        }

        # 2. ჩვენი ახალი მოდულები (Portal, Login, Worklist)
        location /login {
            proxy_pass http://pacs-portal:8000/login;
            proxy_set_header Host $host;
        }

        location /auth/ {
            proxy_pass http://pacs-portal:8000/auth/;
            proxy_set_header Host $host;
        }

        location /doctor/ {
            proxy_pass http://pacs-portal:8000/doctor/;
            proxy_set_header Host $host;
            client_max_body_size 0;
            proxy_read_timeout 600;
            proxy_send_timeout 600;
        }

        # 3. თქვენი ორიგინალური OHIF ბლოკი (ოდნავ შეცვლილი)
        # ეს ბლოკი ახლა მოემსახურება /viewer-ს და ყველა სხვა საჭირო ფაილს.
        # აქ შენარჩუნებულია თქვენი ყველა sub_filter (ლოგო, გაზიარების ღილაკი).
        location / {
            proxy_pass http://pacs-ohif:80;
            
            proxy_set_header Accept-Encoding ""; 
            proxy_set_header Host $host;

            # --- თქვენი ორიგინალური მაგია (AE_TITLE და ლოგო) ---
            sub_filter 'AE_TITLE_PLACEHOLDER' '$ae_title_value';
            sub_filter '<link rel="icon" href="' '<link rel="icon" href="/favicon.ico?v=2" x="';
            sub_filter '<link rel="apple-touch-icon" href="' '<link rel="apple-touch-icon" href="/favicon.ico?v=2" x="';
            
            # --- გაზიარების სკრიპტის ჩამატება ---
            sub_filter '</body>' '<script src="/share-button.js"></script></body>';
            
            sub_filter_once on;
            
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            
            # ქეშირების გათიშვა, რომ ცვლილებები მაშინვე გამოჩნდეს
            add_header Cache-Control "no-store, no-cache, must-revalidate";
        }

        # --- პაციენტის პორტალი (Python) ---
        location /p/ {
    proxy_pass http://pacs-portal:8000; # ⚠️ ბოლოში /p/ აღარ დაუწეროთ!
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}
        

        # --- ᲤᲝᲜᲘᲡ ᲓᲐᲛატება ---

        location = /p/bg.jpg {
            alias /etc/nginx/scripts/background.jpg;
        }

        location /dcm4chee-arc/ {
            # აქ proxy_pass-ს აღარ აქვს /dcm4chee-arc/ ბოლოში, რომ 'if'-მა არ გაჭედოს
            if ($cookie_patient_auth) {
                proxy_pass http://pacs-arc:8080;
                break;
            }
            proxy_pass http://pacs-arc:8080;
            
            client_max_body_size 0;
            proxy_buffering off;
            proxy_read_timeout 600;
        }
        
        # --- ადმინ პანელების დაბლოკვა ---
        location /admin/ {
            allow 10.10.0.0/23; 
            allow 10.10.4.0/23; 
            allow 10.10.14.0/23; 
            allow 10.10.6.0/23;
            allow 192.168.20.239;
            allow 192.168.20.231;
            deny all;
            proxy_pass http://pacs-keycloak:8080/admin/;
        }

        location /realms/master/ {
            allow 10.10.0.0/23; 
            allow 10.10.4.0/23; 
            allow 10.10.14.0/23; 
            allow 10.10.6.0/23;
            allow 192.168.20.239;
            allow 192.168.20.231;
            deny all;
            proxy_pass http://pacs-keycloak:8080/realms/master/;
        }

        location /dcm4chee-arc/ui2/ {
            allow 10.10.0.0/23; 
            allow 10.10.4.0/23; 
            allow 10.10.14.0/23; 
            allow 10.10.6.0/23;
            allow 192.168.20.239;
            allow 192.168.20.231;
            deny all;
            proxy_pass http://pacs-arc:8080/dcm4chee-arc/ui2/;
        }

        # 1. მთავარი ადმინ ჰაბი (Hub)
        location /manage/dashboard {
            proxy_pass http://pacs-portal:8000/manage/dashboard;
            proxy_set_header Host $host;
        }

        # 2. გაზიარების ლოგები
        location /manage/logs {
            proxy_pass http://pacs-portal:8000/manage/logs;
            proxy_set_header Host $host;
        }

        # 3. ღამის მიგრაციის მართვა
        location /manage/migration {
            proxy_pass http://pacs-portal:8000/migration;
            proxy_set_header Host $host;
        }
        location /manage/migration/set {
            proxy_pass http://pacs-portal:8000/migration/set;
            proxy_set_header Host $host;
        }

        # 4. დღის სინქრონიზაცია (Live Sync)
        location /manage/sync-live/ {
            proxy_pass http://pacs-portal:8000/sync-live;
            proxy_set_header Host $host;
        }
        location /manage/sync-live/set {
            proxy_pass http://pacs-portal:8000/sync-live/set;
        }


        # 5. სტატისტიკა (მოდალობები)
        location /manage/stats/ {
            proxy_pass http://pacs-stats:8002/;
            proxy_set_header Host $host;
        }
        #pacs admin paneli
        location /pacs-admin/ {
            allow 10.10.0.0/23;
            allow 10.10.4.0/23;
            allow 10.10.14.0/23;
            allow 192.168.20.239;
            allow 192.168.20.231;
            deny all;
            proxy_pass http://pacs-admin:8005/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Nexrad Admin Hub — license + dashboard
        # შენიშვნა: /admin/ Keycloak-ს აქვს, ამიტომ /pacs-hub/ ვიყენებთ
        location /pacs-hub/ {
            allow 10.10.0.0/23;
            allow 10.10.4.0/23;
            allow 10.10.14.0/23;
            allow 192.168.20.239;
            allow 192.168.20.231;
            deny all;
            proxy_pass http://pacs-admin:8005/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }    


        location /old-pacs/ {
            # მისამართი 8443 პორტზე (სადაც სურათებია)
            proxy_pass https://pacs.innovamedical.ge:8443/dcm4chee-arc/;

            # SSL-ის სისუსტის იგნორირება (აუცილებელია თქვენი სერვერისთვის)
            proxy_ssl_verify off;
            proxy_ssl_server_name on;
            proxy_ssl_session_reuse off;

            # თქვენი 5-წუთიანი ტოკენი
            proxy_set_header Authorization "Bearer eyJhbGciOiJSUzI1NiIsInR5cCIgOiAiSldUIiwia2lkIiA6ICI5R3RtOXowTHhaMXVpcG0xTGhYdFFoMVQ0NzhpTUtBTnRZVFYxQVF0eFU4In0..p4p02XozVHyVjllJSFTW4jtohZ-DsZuwLoE3WojNOipoTGd_Z6M9tyqzh3fE_if_fUT_Ol_lD2zIAyrmPiLT97nwQkmRUyg7WEXrhvYS096ccGuyXa-7ork9kIb6f200xdWu_3L7-iAeBZQ48wmmGU_MJnFtK2rI-bzrgbM2Kdy3F5Lw7BI6fAPlMw89Fb2T1jIOodmI1uTmZFjaxz85a__4j6x7ypH8Q_5f9_plBslxOKIxES8ns_g719dak4DB0Pjocy67o6gn1HZtoVB2VlLNXMAAZMLEkpAg0qZJY0_KE7gZ9wIXLjqd8JK_1ofq-ZePXmjUrPLfX25-RP4Zhw";

            # CORS (აუცილებელია OHIF-ისთვის)
            proxy_hide_header 'Access-Control-Allow-Origin';
            add_header 'Access-Control-Allow-Origin' 'https://ris.innovamedical.ge' always;
            add_header 'Access-Control-Allow-Credentials' 'true' always;
            add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS' always;
            add_header 'Access-Control-Allow-Headers' 'Authorization, Content-Type, Range' always;

            proxy_set_header Host pacs.innovamedical.ge;
            proxy_buffering off;
            client_max_body_size 0;
            proxy_set_header X-Real-IP "";
        }   

        # --- Keycloak ---
        location /realms/ { proxy_pass http://pacs-keycloak:8080/realms/; 
        }
        location /resources/ { proxy_pass http://pacs-keycloak:8080/resources/; 
        }
        location /js/ { proxy_pass http://pacs-keycloak:8080/js/; 
        }


        # --- სკრიპტები ---
        location = /share-button.js { alias /etc/nginx/scripts/share-button.js; 
        }
        
        location  /resources/innova/login/img/favicon.ico {
            alias /etc/nginx/static/favicon.ico;
        }
        }
        
        #location = /favicon.ico {
         #   alias /etc/nginx/static/favicon.ico;
        #}
        #location = /favicon.ico { alias /etc/nginx/static/favicon.ico; }
    
        
    # ══════════════════════════════════════════════════
    # Nexrad Vendor Dashboard — nexrad.innovamedical.ge
    # ══════════════════════════════════════════════════
    server {
        listen 80;
        server_name nexrad.innovamedical.ge;
        return 301 https://$host$request_uri;
    }

    server {
        listen 443 ssl;
        server_name nexrad.innovamedical.ge;

        ssl_certificate     /etc/nginx/certs/live/ris.innovamedical.ge/fullchain.pem;
        ssl_certificate_key /etc/nginx/certs/live/ris.innovamedical.ge/privkey.pem;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        location / {
            proxy_pass http://nexrad:8010/;
        }
    }

    # ══════════════════════════════════════════════════════
    # PacsFlow Vendor Dashboard — pacsflow.innovamedical.ge
    # (დროებითი სუბდომეინი — მოგვიანებით pacsflow.ge-ზე გადავა)
    # ══════════════════════════════════════════════════════
    server {
        listen 80;
        server_name pacsflow.innovamedical.ge;
        return 301 https://$host$request_uri;
    }

    server {
        listen 443 ssl;
        server_name pacsflow.innovamedical.ge;

        ssl_certificate     /etc/nginx/certs/live/ris.innovamedical.ge/fullchain.pem;
        ssl_certificate_key /etc/nginx/certs/live/ris.innovamedical.ge/privkey.pem;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # favicon
        location = /favicon.ico {
            alias /etc/nginx/static/favicon.ico;
            access_log off;
        }

        location / {
            proxy_pass http://pacsflow:8010/;
        }
    }
}
